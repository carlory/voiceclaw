# VoiceClaw Server Configuration

# Server
HOST=127.0.0.1
PORT=8765
DEBUG=false

# OpenClaw Gateway
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=your-token-here
OPENCLAW_MODEL=openclaw

# Qwen3-ASR
ASR_MODEL=Qwen/Qwen3-ASR-1.7B
ASR_DEVICE=mps

# Qwen3-TTS
TTS_MODEL=Qwen/Qwen3-TTS-1.7B
TTS_DEVICE=mps
TTS_SPEAKER=default

# VAD
VAD_THRESHOLD=0.5
VAD_MIN_SILENCE_MS=500

# Audio
SAMPLE_RATE=16000
AUDIO_CHANNELS=1
